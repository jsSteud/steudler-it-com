      "Bash(python3 -c \"import json,sys; d=json.load\\(sys.stdin\\); cfg=d['DistributionConfig']; print\\('Cert:', json.dumps\\(cfg['ViewerCertificate'], indent=2\\)\\); print\\('DefaultRoot:', cfg['DefaultRootObject']\\); print\\('Enabled:', cfg['Enabled']\\)\")",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code} via www: %{url_effective}\\\\n\" -L https://www.steudler-it.com/)",
      "Bash(curl -s -o /dev/null -w \"HTTP %{http_code} via apex: %{url_effective}\\\\n\" -L https://steudler-it.com/)",
